# Flask
FLASK_ENV=development
SECRET_KEY=change-me-to-a-long-random-string

# Database
# Relative SQLite paths are resolved relative to Flask's instance/ folder,
# so `sqlite:///dev.db` ends up at instance/dev.db. Do NOT prefix with instance/.
DEV_DATABASE_URL=sqlite:///dev.db
TEST_DATABASE_URL=sqlite:///:memory:
DATABASE_URL=sqlite:///ntkrv.db

# Mail (SMTP)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=

# Admin (used by utils/create_admin.py and tests)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# Only this address can request a password-reset link. Must match exactly
# the email entered on /admin-auth/forgot-password (case-insensitive).
# Without this, the reset endpoint silently no-ops.
ADMIN_RESET_EMAIL=

# Analytics (Google Analytics 4). Leave empty in dev; set to G-XXXXXXXXXX
# in production. GA4 loads only when this is set, and only fires after
# the visitor accepts the cookie banner (Consent Mode v2).
GA_MEASUREMENT_ID=

# Email shown on the privacy policy as the GDPR contact. Defaults to
# contact@ntkrv.dev. Set to a dedicated alias if you prefer.
PRIVACY_CONTACT_EMAIL=
